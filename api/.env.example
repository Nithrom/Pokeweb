# Supabase (recomendado) — Project Settings → Database → Connection string (URI)
# Usa "Session mode" o conexión directa al puerto 5432
DATABASE_URL=postgresql://postgres:TU_PASSWORD@db.TU_PROJECT_REF.supabase.co:5432/postgres

# MariaDB local / Docker (solo si NO defines DATABASE_URL)
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_NAME=pokeweb
# DB_USER=pokeweb_user
# DB_PASS=pokeweb_pass

# Flask
FLASK_ENV=development
