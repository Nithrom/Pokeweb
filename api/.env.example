# Copia a api/.env y rellena (no subas .env a Git).

# ── Supabase (recomendado en producción) ──
# Project Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# ── MariaDB local / Docker (sin DATABASE_URL) ──
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USER=pokeweb_user
# DB_PASS=pokeweb_pass
# DB_NAME=pokeweb

FLASK_ENV=development
FLASK_DEBUG=1
