# Supabase — Project Settings → Database → Connection string
# Local: URI directa (db.PROJECT.supabase.co:5432) suele ir bien.
# Railway/Render: usa "Connection pooling" → Session (5432) o Transaction (6543).
#   El host es *.pooler.supabase.com y el usuario postgres.PROJECT_REF (no solo postgres).
# Ejemplo pooler (copia la tuya del panel, región puede variar):
# DATABASE_URL=postgresql://postgres.TU_PROJECT_REF:TU_PASSWORD@aws-0-eu-west-1.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres:TU_PASSWORD@db.TU_PROJECT_REF.supabase.co:5432/postgres

# MariaDB local / Docker (solo si NO defines DATABASE_URL)
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_NAME=pokeweb
# DB_USER=pokeweb_user
# DB_PASS=pokeweb_pass

# Flask
FLASK_ENV=development
